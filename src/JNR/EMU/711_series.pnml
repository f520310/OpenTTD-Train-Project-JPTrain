/*---GFX: Year Dependent Switches---*/
//711 Orginal FRONT Cab Light
switch(FEAT_TRAINS, SELF, sw_711_gfx_spriteset_front, current_year){
 0..1978: spriteset_711_front_nobeam;
 default: spriteset_711_front_beam;
}

//711 Orginal BACK Cab Light
switch(FEAT_TRAINS, SELF, sw_711_gfx_spriteset_back, current_year){
 0..1978: spriteset_711_back_nobeam;
 default: spriteset_711_back_beam;
}

//711 Orginal MID Pantograph
switch(FEAT_TRAINS, SELF, sw_711_gfx_spriteset_713_mid_panto, current_year){
 0..2004: spriteset_711_mid_darm;
 default: spriteset_711_mid_sarm;
}

//711 Refurb MID Pantograph
switch(FEAT_TRAINS, SELF, sw_711_gfx_spriteset_713_mid_panto_refurb, current_year){
 0..2004: spriteset_711_mid_refurb_darm;
 default: spriteset_711_mid_refurb_sarm;
}

//711 Orginal BACK Pantograph Ver
switch(FEAT_TRAINS, SELF, sw_711_gfx_spriteset_backpanto, current_year){
