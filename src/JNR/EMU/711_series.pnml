/*---GFX: Livery Refitting Switches---*/
//Main Switches
switch(FEAT_TRAINS, SELF, sw_711_gfx_mucar, cargo_subtype){
  3: spriteset_711_mid_refurb_ac;
  2: sw_711_gfx_spriteset_713_mid_panto_refurb;
  1: sw_711_gfx_spriteset_713_mid_panto_refurb;
  0: sw_711_gfx_spriteset_713_mid_panto;
}
switch(FEAT_TRAINS, SELF, sw_711_gfx_main, cargo_subtype) {
  3: sw_711_gfx_frontback_flipcheck_refurb_ac;
  2: sw_711_gfx_frontback_flipcheck_refurb_3door;
  1: sw_711_gfx_frontback_flipcheck_refurb_2door;
  0: sw_711_gfx_frontback_flipcheck;
}

//Menu Switches
switch(FEAT_TRAINS, SELF, sw_711_subtypetext_mucar, cargo_subtype) {
  3: string(JNR711_NEWAC);
  2: string(JNR711_NEW3D);
  1: string(JNR711_NEW2D);
  0: string(JNR711_OLD);
}
switch(FEAT_TRAINS, SELF, sw_711_subtypetext_main, cargo_subtype) {
  3: string(JNR711_NEWAC);
  2: string(JNR711_NEW3D);
  1: string(JNR711_NEW2D);
  0: string(JNR711_OLD);
}
