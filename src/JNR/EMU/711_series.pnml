/*---GFX: Front/Back Cab Car Switches + DUAL_HEADED fix---*/
//711 Orginal
switch(FEAT_TRAINS, SELF, sw_711_gfx_pantocheck, position_in_vehid_chain){
 0: sw_711_gfx_spriteset_back;
 default: sw_711_gfx_spriteset_backpanto;
}
switch(FEAT_TRAINS, SELF, sw_711_gfx_frontback_flipcheck, vehicle_is_flipped){
 0: sw_711_gfx_spriteset_front;
