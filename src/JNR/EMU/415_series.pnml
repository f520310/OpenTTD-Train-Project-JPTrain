0 : sw_415_gfx_frontback_flipcheck_initial;
1 : sw_415_gfx_frontback_flipcheck_joban;
2 : sw_415_gfx_frontback_flipcheck_kyushu;
3 : sw_415_gfx_frontback_flipcheck_jrw_regional_1;
4 : sw_415_gfx_frontback_flipcheck_jrw_regional_2;
}
