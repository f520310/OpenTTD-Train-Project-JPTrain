/*---GFX: Livery Refitting Switches---*/
//Main Switches
switch(FEAT_TRAINS, SELF, sw_EMU119_gfx_mucar,  cargo_subtype) {
  0: sw_EMU119_gfx_cargosubtype;
  1: sw_EMU119_gfx_cargosubtype;
  2: sw_EMU119_gfx_cargosubtype;
  3: sw_EMU119_gfx_cargosubtype;
}
switch(FEAT_TRAINS, SELF, sw_EMU119_gfx_main, cargo_subtype) {
  0: sw_EMU119_gfx_std_frontback_flipcheck;
  1: sw_EMU119_gfx_std_gable_frontback_flipcheck;
  2: sw_EMU119_gfx_ube_frontback_flipcheck;
  3: sw_EMU119_gfx_ube_gable_frontback_flipcheck;
}
switch(FEAT_TRAINS, SELF, sw_EMU119_gfx_single, cargo_subtype) {
  0: spriteset_EMU119_std_single;
  1: spriteset_EMU119_std_gable_single;
  2: spriteset_EMU119_ube_single;
  3: spriteset_EMU119_ube_gable_single;
}
//Menu Switches
switch(FEAT_TRAINS, SELF, sw_EMU119_subtypetext_mucar, cargo_subtype) {
  0: string(LV_STANDARD);
  1: string(LV_VARITION_END1);
  2: string(LV_UBEON);
  3: string(LV_VARITION_END2);
}
switch(FEAT_TRAINS, SELF, sw_EMU119_subtypetext_main, cargo_subtype) {
  0: string(LV_STANDARD);
  1: string(LV_VARITION_END1);
  2: string(LV_UBEON);
  3: string(LV_VARITION_END2);
}
switch(FEAT_TRAINS, SELF, sw_EMU119_subtypetext_single, cargo_subtype) {
  0: string(LV_STANDARD);
  1: string(LV_VARITION_END1);
  2: string(LV_UBEON);
  3: string(LV_VARITION_END2);
}
