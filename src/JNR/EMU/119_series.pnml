//Coupling
  switch(FEAT_TRAINS, SELF, sw_EMU119_attach_vehid, [vehicle_type_id == emu_119 || vehicle_type_id == emu_119sinlge ||vehicle_type_id == mu_car]) {
  0: return string(MU_UNIQUE);
  }
  switch(FEAT_TRAINS, SELF, sw_EMU119_single_attach_vehid, [vehicle_type_id == emu_119 || vehicle_type_id == emu_119sinlge]) {
  0: return string(MU_UNIQUE);
  }

item(FEAT_TRAINS, emu_119) {
    property {
        name:                         string(JNR_119);
        introduction_date:            date(1932, 04, 05);
        model_life:                   10;
        vehicle_life:                 42;
        reliability_decay:            18;

        cargo_capacity:               param_capacity_local;
        loading_speed:                param_loading_3D;
        cargo_age_period:             param_decay_local;
        cost_factor:                  17;
        running_cost_factor:          54;

        speed:                        85 km/h;
        track_type:                   TR_1067_DC;
        power:                        420 kW;
        weight:                       38 ton;

        climates_available:           ALL_CLIMATES;
        ai_special_flag:              AI_FLAG_PASSENGER;
        sprite_id:                    SPRITE_ID_NEW_TRAIN;
        misc_flags:                   bitmask(TRAIN_FLAG_MU);
        refittable_cargo_classes:     bitmask(CC_PASSENGERS);
        non_refittable_cargo_classes: bitmask();
        refit_cost:                   0;
        dual_headed:                  1;
        ai_engine_rank:               0;

        running_cost_base:            RUNNING_COST_ELECTRIC;
        engine_class:                 ENGINE_CLASS_ELECTRIC;
        visual_effect_and_powered:    visual_effect_and_powered(VISUAL_EFFECT_ELECTRIC, 4, ENABLE_WAGON_POWER);

        tractive_effort_coefficient:  0.2;
        air_drag_coefficient:         0.07;
        bitmask_vehicle_info:         0;
        length: 8;
    }
    /*Graphics and Callbacks*/
      graphics {
        default:                sw_EMU119_gfx_main;
		    purchase:               spriteset_EMU119_purchase;
		    additional_text:	      return string(JNR_119_DESC);
        cargo_subtype_text:     sw_EMU119_subtypetext_main;
        can_attach_wagon:			  sw_EMU119_attach_vehid;
        //start_stop:           ;
    }
    /*Multiple Unit Car*/
      livery_override(mu_car){
        default:                      sw_EMU119_gfx_mucar;
        cargo_capacity:               param_capacity_local;
        loading_speed:                param_loading_3D;
        cargo_age_period:             param_decay_local;
        cargo_subtype_text:           sw_EMU119_subtypetext_mucar;
        power: 132;
        weight: 119;
      }
}

