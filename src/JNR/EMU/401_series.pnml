alternative_sprites(spriteset_401_mid_panto_joban,     ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP,     "gfx/JNR/emu415/standard/joban/401-2-3.png")      {tmpl_std(0, 1)}
