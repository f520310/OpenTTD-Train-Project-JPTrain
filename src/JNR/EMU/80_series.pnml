alternative_sprites(spriteset_80_back_panto2,                          ZOOM_LEVEL_NORMAL, BIT_DEPTH_32BPP,       "gfx/JNR/emu80/80-cabpantographs.png")             {tmpl_std_rev(0, 75)}

