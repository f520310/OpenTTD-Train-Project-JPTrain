/*---GFX: Livery Refitting Switches---*/
//Main Switches
switch(FEAT_TRAINS, SELF, sw_80_gfx_mucar,  cargo_subtype) {
  default: sw_80_gfx_cargosubtype;
}
switch(FEAT_TRAINS, SELF, sw_80_gfx_main,  cargo_subtype) {
  4: sw_80_gfx_862_kansai_frontback_flipcheck;
  3: sw_80_gfx_852_frontback_flipcheck;
  2: sw_80_gfx_85_frontback_flipcheck;
  1: sw_80_gfx_862_frontback_flipcheck;
  0: sw_80_gfx_861_frontback_flipcheck;
}

//Menu Switches
switch(FEAT_TRAINS, SELF, sw_80_subtypetext_mucar, cargo_subtype) {
  //11: string(jnr80_kansai_pt);
  //10: string(jnr80_kansai_mu);
  //9: string(jnr_80_DIV_kansai);
  //8: string(jnr80_shonan_gr);
  //7: string(jnr80_shonan_pt);
  //6: string(jnr80_shonan_mu);
  //5: string(jnr_80_DIV_shonan);
  4: string(LV_KANSAI); //Kansai Livery (KUHA 86 Shonan face type)
  3: string(LV_VARITION_END1); //Shonan Livery (KUHA 85 type + KUHA 86 Shonan face type)
  2: string(LV_VARITION_MID2); //Shonan Livery (KUHA 85 type + KUHA 86 initial type)
  1: string(LV_VARITION_MID1); //Shonan Livery (KUHA 86 initial face type)
  0: string(LV_SHONAN); //Shonan Livery (KUHA 86 Shonan face type)
}
switch(FEAT_TRAINS, SELF, sw_80_subtypetext_main, cargo_subtype) {
  4: string(LV_KANSAI); //Kansai Livery (KUHA 86 Shonan face type)
  3: string(LV_VARITION_END1); //Shonan Livery (KUHA 85 type + KUHA 86 Shonan face type)
  2: string(LV_VARITION_MID2); //Shonan Livery (KUHA 85 type + KUHA 86 initial type)
  1: string(LV_VARITION_MID1); //Shonan Livery (KUHA 86 initial face type)
  0: string(LV_SHONAN); //Shonan Livery (KUHA 86 Shonan face type)
}
