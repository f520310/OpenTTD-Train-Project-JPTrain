/*---GFX: Livery Refitting Switches---*/

//Main Switches
switch(FEAT_TRAINS, SELF, sw_207_gfx_mucar,  cargo_subtype) {
  5: sw_207_gfx_pantograph_pos_jrwref_middle;
  4: sw_207_gfx_pantograph_pos_jrwref_end;
  3: sw_207_gfx_pantograph_pos_jrwnew_middle;
  2: sw_207_gfx_pantograph_pos_jrwnew_end;
  1: sw_207_gfx_pantograph_pos_jrw_end_maincounter;
  0: sw_207_gfx_pantograph_pos_jrw_middle;
}
switch(FEAT_TRAINS, SELF, sw_207_gfx_main,  cargo_subtype) {
  5: sw_207_gfx_frontback_flipcheck_jrwref_midp;
  4: sw_207_gfx_frontback_flipcheck_jrwref_cabp;
  3: sw_207_gfx_frontback_flipcheck_jrwnew_midp;
  2: sw_207_gfx_frontback_flipcheck_jrwnew_cabp;
  1: sw_207_gfx_frontback_flipcheck_jrw_sp;
  0: sw_207_gfx_frontback_flipcheck_jrw_dp;
}

//Menu Switches
switch(FEAT_TRAINS, SELF, sw_207_subtypetext_mucar, cargo_subtype) {
  5: string(JRWnewremodelpanto_LV);
  4: string(JRWnewremodel_LV);
  3: string(JRWnewpanto_LV);
  2: string(JRWnew_LV);
  1: string(JRWbluepanto_LV);
  0: string(JRWblue_LV);
}
switch(FEAT_TRAINS, SELF, sw_207_subtypetext_main, cargo_subtype) {
  5: string(JRWnewremodelpanto_LV);
  4: string(JRWnewremodel_LV);
  3: string(JRWnewpanto_LV);
  2: string(JRWnew_LV);
  1: string(JRWbluepanto_LV);
  0: string(JRWblue_LV);
}
