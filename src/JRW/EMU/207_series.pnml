 0: spriteset_207_front_np_repaint;
 default: sw_207_gfx_pantocheck_jrwnew_midp;
}

//207 Refurb cab panto
switch(FEAT_TRAINS, SELF, sw_207_gfx_pantocheck_jrwref_cabp, position_in_vehid_chain){
 0: spriteset_207_back_tp_refurb;
 default: spriteset_207_back_tp_refurb;
}
switch(FEAT_TRAINS, SELF, sw_207_gfx_frontback_flipcheck_jrwref_cabp, vehicle_is_flipped){
 0: spriteset_207_front_np_refurb;
 default: sw_207_gfx_pantocheck_jrwref_cabp;
}
//207 Refurb mid panto
switch(FEAT_TRAINS, SELF, sw_207_gfx_pantocheck_jrwref_midp, position_in_vehid_chain){
 0: spriteset_207_back_np_refurb;
 default: spriteset_207_back_tp_refurb;
}
switch(FEAT_TRAINS, SELF, sw_207_gfx_frontback_flipcheck_jrwref_midp, vehicle_is_flipped){
 0: spriteset_207_front_np_refurb;
 default: sw_207_gfx_pantocheck_jrwref_midp;
}
